    "custom_liquid_YXWHeB": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<!--\n  Everstory PDP — GENERAL block (EN). Horizon Custom Liquid, product info 블록 *밖*.\n  모든 상품 페이지에 1벌만 둔다. 이 블록이 .es-pdp <style> 를 페이지에 까는 단일 SOT.\n  product-specific(intro)는 everstory_pdp_product_intro_en.html — product info 블록 안 metafield.\n\n  버킷:\n  - 전 상품 공용: Options>Material, Before you order, Photo quality, Color\n  - 비-Package 공용: Options>Size, Sizes(one sheet one size + grid + by-longest-edge)\n    → is_package 판별자로 조건부. Package 는 size 선택 개념이 없음(tier 큐레이션).\n\n  운영 규칙: product-specific 블록을 넣는 상품 페이지엔 이 블록도 반드시 같이 둔다\n  (안쪽 fragment 가 여기 <style> 에 의존).\n\n  Content SOT: everstory_product_detail_pdp_block.html (KO 원본). KO/EN 카피만 차이.\n  구조 변경 시 KO 분리본 + full_template 3-way 동기화 필요(후속).\n\n  Shopify Files 의존: cat_w.svg, cat_h.svg, solo_*.png, teo_focused.png, teo_outfocused.png\n-->\n<style>\n    .es-pdp {\n      /* Brand tokens — docs/design/tokens.json (colors.web) */\n      --text-primary:   #000000;\n      --text-secondary: #4A4A4A;\n      --text-muted:     #8A8580;\n      --text-inverse:   #FFFFFF;\n      --accent-coral:   #FBAAA8;\n\n      --bg-canvas:  #FEFDFE;\n      --bg-muted:   #F8F5F2;\n      --bg-warm:    #E0D3CB;\n\n      --line:        #ECE6E0;\n      --line-strong: #1A1A1A;\n\n      /* Editorial / luxury: no drop shadows, no panel borders, sharp corners.\n         Depth comes from spacing + bg.warm callouts. */\n      --max: 1120px;\n\n      /* Inherit 차단 — Horizon body 의 font/color/letter-spacing 가 들어오지 않게 */\n      font-family: 'Pretendard', 'Apple SD Gothic Neo', 'Noto Sans KR',\n                   -apple-system, BlinkMacSystemFont, system-ui, sans-serif;\n      font-weight: 500;\n      letter-spacing: -0.02em;\n      line-height: 1.5;\n      color: var(--text-primary);\n      background: var(--bg-canvas);\n      word-break: keep-all;\n      -webkit-font-smoothing: antialiased;\n    }\n\n    /* Scoped box-sizing — .es-pdp 안쪽만, 글로벌 누수 없음 */\n    .es-pdp,\n    .es-pdp *,\n    .es-pdp *::before,\n    .es-pdp *::after {\n      box-sizing: border-box;\n    }\n\n    /* English brand wordmark — sheet mockup tiny-mark, RGB/CMYK headings */\n    .es-pdp .wordmark {\n      font-family: 'Cormorant Garamond', 'Playfair Display', Georgia, serif;\n      font-weight: 600;\n      font-style: italic;\n      letter-spacing: 0;\n    }\n\n    .es-pdp .es-page {\n      width: min(var(--max), calc(100% - 36px));\n      margin: 0 auto;\n      padding: 56px 0 88px;\n    }\n\n    .es-pdp .es-section {\n      margin: 0 0 112px;\n    }\n\n    .es-pdp .es-section:last-child {\n      margin-bottom: 0;\n    }\n\n    .es-pdp .es-section-shell {\n      padding: clamp(28px, 4vw, 56px) clamp(20px, 4vw, 56px);\n    }\n\n    /* notice 섹션만 pearl-grey callout block 유지 */\n    .es-pdp .es-notice-section .es-section-shell {\n      background: var(--bg-warm);\n      padding: clamp(48px, 6vw, 88px) clamp(28px, 5vw, 72px);\n    }\n\n    /* Eyebrow — 작은 uppercase coral 라벨 */\n    .es-pdp .es-eyebrow {\n      display: block;\n      margin: 0 0 18px;\n      color: var(--accent-coral);\n      font-size: clamp(10px, 1vw, 12px);\n      font-weight: 700;\n      letter-spacing: 0.22em;\n      text-transform: uppercase;\n      text-align: center;\n    }\n\n    /* 통일된 섹션 헤딩: eyebrow + h2 + (optional) sub */\n    .es-pdp .heading-block {\n      text-align: center;\n      margin: 0 0 56px;\n    }\n\n    .es-pdp .heading-block h2 {\n      margin: 0;\n      font-weight: 700;\n      font-size: clamp(26px, 3.4vw, 42px);\n      line-height: 1.25;\n      letter-spacing: -0.035em;\n      color: var(--text-primary);\n    }\n\n    .es-pdp .heading-block .sub {\n      margin: 18px auto 0;\n      max-width: 620px;\n      color: var(--text-secondary);\n      font-size: clamp(14px, 1.4vw, 17px);\n      line-height: 1.85;\n    }\n\n    .es-pdp .copy {\n      max-width: 720px;\n      margin: 0 auto;\n      text-align: center;\n      color: var(--text-secondary);\n      font-size: clamp(15px, 1.5vw, 18px);\n      line-height: 1.85;\n    }\n\n    .es-pdp .image-placeholder {\n      width: 100%;\n      height: 100%;\n      min-height: 220px;\n      display: grid;\n      place-items: center;\n      text-align: center;\n      color: var(--text-muted);\n      font-size: 12px;\n      letter-spacing: 0.04em;\n      line-height: 1.6;\n      padding: 24px;\n      background: var(--bg-muted);\n    }\n\n    /* Generic img — .es-pdp scope 안에서만 적용. 글로벌 누수 없음.\n       .sheet-image (object-fit:contain) 가 specificity 로 이 룰을 덮어씀. */\n    .es-pdp img {\n      display: block;\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n    }\n\n    /* 1. 제품 소개 */\n    .es-pdp .photo-pair {\n      display: grid;\n      grid-template-columns: 1fr 0.9fr;\n      gap: 18px;\n      margin-bottom: 44px;\n    }\n\n    .es-pdp .photo-frame {\n      min-height: 460px;\n      background: var(--bg-muted);\n      overflow: hidden;\n    }\n\n    .es-pdp .single-photo {\n      max-width: 760px;\n      margin: 0 auto 36px;\n      background: var(--bg-muted);\n      overflow: hidden;\n      aspect-ratio: 4 / 3;\n    }\n\n    /* 3. 옵션 */\n    .es-pdp .option-compare {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 36px;\n    }\n\n    .es-pdp .option-block { display: grid; gap: 16px; }\n\n    .es-pdp .option-title {\n      margin: 0;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      gap: 8px;\n      color: var(--text-primary);\n      font-size: 15px;\n      font-weight: 700;\n      letter-spacing: -0.01em;\n    }\n\n    .es-pdp .status-icon {\n      width: 16px;\n      height: 16px;\n      flex-shrink: 0;\n    }\n\n    .es-pdp .status-icon--ok { color: #4A7C59; }\n    .es-pdp .status-icon--no { color: #C04545; }\n\n    .es-pdp .option-image {\n      aspect-ratio: 4 / 5;\n      background: var(--bg-muted);\n      overflow: hidden;\n    }\n\n    .es-pdp .option-detail {\n      text-align: center;\n      color: var(--text-secondary);\n      font-size: 14px;\n      line-height: 1.75;\n    }\n\n    .es-pdp .option-detail strong {\n      display: block;\n      margin-bottom: 4px;\n      color: var(--text-primary);\n      font-weight: 700;\n    }\n\n    /* 4. 시트 구성 */\n    .es-pdp .size-grid {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 56px 42px;\n    }\n\n    .es-pdp .size-card { min-width: 0; text-align: center; }\n\n    .es-pdp .size-title {\n      margin: 0 0 16px;\n      font-weight: 700;\n      font-size: clamp(17px, 1.9vw, 22px);\n      letter-spacing: -0.02em;\n      color: var(--text-primary);\n    }\n\n    .es-pdp .size-title small {\n      margin-left: 8px;\n      font-weight: 500;\n      font-size: 12px;\n      letter-spacing: 0;\n      color: var(--text-muted);\n      vertical-align: middle;\n    }\n\n    .es-pdp .mockup-wrap {\n      position: relative;\n      background: var(--bg-canvas);\n    }\n\n    .es-pdp .measure-top {\n      position: absolute;\n      top: 0;\n      left: 5%;\n      right: 5%;\n      height: 1px;\n      background: var(--accent-coral);\n    }\n\n    .es-pdp .measure-top::before,\n    .es-pdp .measure-top::after {\n      content: \"\";\n      position: absolute;\n      top: -4px;\n      width: 1px;\n      height: 8px;\n      background: var(--accent-coral);\n    }\n\n    .es-pdp .measure-top::before { left: 0; }\n    .es-pdp .measure-top::after { right: 0; }\n\n    .es-pdp .measure-label-top {\n      position: absolute;\n      top: -14px;\n      left: 50%;\n      transform: translateX(-50%);\n      color: var(--accent-coral);\n      font-size: 10px;\n      letter-spacing: 0.04em;\n    }\n\n    .es-pdp .measure-left {\n      position: absolute;\n      top: 5%;\n      bottom: 5%;\n      left: -1%;\n      width: 1px;\n      background: var(--accent-coral);\n    }\n\n    .es-pdp .measure-left::before,\n    .es-pdp .measure-left::after {\n      content: \"\";\n      position: absolute;\n      left: -4px;\n      width: 8px;\n      height: 1px;\n      background: var(--accent-coral);\n    }\n\n    .es-pdp .measure-left::before { top: 0; }\n    .es-pdp .measure-left::after { bottom: 0; }\n\n    .es-pdp .measure-label-left {\n      position: absolute;\n      left: -22px;\n      top: 50%;\n      transform: translateY(-50%) rotate(-90deg);\n      color: var(--accent-coral);\n      font-size: 10px;\n      letter-spacing: 0.04em;\n      white-space: nowrap;\n    }\n\n    /* A5 시트 mockup — Shopify Files 의 solo_*.png 직접 표시 */\n    .es-pdp .sheet-image {\n      display: block;\n      width: 100%;\n      aspect-ratio: 148 / 210;\n      object-fit: contain;\n      background: var(--bg-canvas);\n    }\n\n    /* Mixed 카드는 hero 배치 — 한 시트 안의 여러 사이즈 큐레이션 강조 */\n    .es-pdp .size-card.mixed { grid-column: 1 / -1; }\n    .es-pdp .size-card.mixed .mockup-wrap { max-width: 50%; margin: 0 auto; }\n\n    .es-pdp .caption {\n      margin: 16px 0 0;\n      color: var(--text-secondary);\n      font-size: 13px;\n      line-height: 1.7;\n    }\n\n    /* 5. 사이즈 가이드 */\n    .es-pdp .measure-group {\n      margin-top: 56px;\n    }\n\n    .es-pdp .measure-group:first-of-type { margin-top: 0; }\n\n    .es-pdp .group-label {\n      width: fit-content;\n      margin: 0 auto 40px;\n      padding-bottom: 8px;\n      border-bottom: 1px solid var(--text-primary);\n      color: var(--text-primary);\n      text-align: center;\n      font-size: 13px;\n      letter-spacing: 0.02em;\n      font-weight: 700;\n    }\n\n    .es-pdp .size-rule {\n      max-width: 520px;\n      margin: clamp(72px, 8vw, 112px) auto 0;\n      text-align: center;\n      color: var(--text-secondary);\n      font-size: clamp(13px, 1.3vw, 15px);\n      line-height: 1.7;\n    }\n\n    .es-pdp .size-rule strong {\n      display: block;\n      margin-bottom: 6px;\n      color: var(--text-primary);\n      font-weight: 700;\n      letter-spacing: -0.01em;\n    }\n\n    .es-pdp .examples {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      align-items: center;\n      justify-items: center;\n      gap: clamp(48px, 6vw, 96px);\n    }\n\n    .es-pdp .example {\n      text-align: center;\n      display: grid;\n      justify-items: center;\n      gap: 14px;\n    }\n\n    .es-pdp .measure-box {\n      --size: 180px;\n      --short-ratio: 1;\n      width: calc(var(--size) * var(--short-ratio));\n      height: var(--size);\n      position: relative;\n      display: grid;\n      place-items: center;\n    }\n\n    /* Orientation — 긴 변 동일 (--size), 짧은 변 = --size × --short-ratio */\n    .es-pdp .measure-box.orientation-h,\n    .es-pdp .measure-box.orientation-v {\n      --size: 240px;\n      --short-ratio: 0.75;\n    }\n    .es-pdp .measure-box.orientation-h {\n      width: var(--size);\n      height: calc(var(--size) * var(--short-ratio));\n    }\n    .es-pdp .measure-box.orientation-v {\n      width: calc(var(--size) * var(--short-ratio));\n      height: var(--size);\n    }\n\n    .es-pdp .guide-square {\n      position: absolute;\n      inset: 0;\n    }\n\n    /* 측정선 — 세로 (왼쪽) */\n    .es-pdp .vertical-measure {\n      position: absolute;\n      left: -36px;\n      top: 0px;\n      bottom: 0px;\n      width: 1px;\n      background: var(--accent-coral);\n    }\n\n    .es-pdp .vertical-measure::before,\n    .es-pdp .vertical-measure::after {\n      content: \"\";\n      position: absolute;\n      left: -4px;\n      width: 8px;\n      height: 1px;\n      background: var(--accent-coral);\n    }\n\n    .es-pdp .vertical-measure::before { top: 0; }\n    .es-pdp .vertical-measure::after { bottom: 0; }\n\n    /* 측정선 — 가로 (위쪽) */\n    .es-pdp .horizontal-measure {\n      position: absolute;\n      top: -36px;\n      left: 0;\n      right: 0;\n      height: 1px;\n      background: var(--accent-coral);\n    }\n\n    .es-pdp .horizontal-measure::before,\n    .es-pdp .horizontal-measure::after {\n      content: \"\";\n      position: absolute;\n      top: -4px;\n      width: 1px;\n      height: 8px;\n      background: var(--accent-coral);\n    }\n\n    .es-pdp .horizontal-measure::before { left: 0; }\n    .es-pdp .horizontal-measure::after { right: 0; }\n\n    .es-pdp .measure-text {\n      position: absolute;\n      color: var(--accent-coral);\n      font-size: clamp(13px, 1.3vw, 16px);\n      letter-spacing: 0.04em;\n      line-height: 1;\n      white-space: nowrap;\n      font-weight: 700;\n    }\n\n    .es-pdp .measure-text--side {\n      left: -45%;\n      top: 50%;\n      transform: translateY(-50%) rotate(-90deg);\n    }\n\n    .es-pdp .measure-text--top {\n      top: -56px;\n      left: 50%;\n      transform: translateX(-50%);\n    }\n\n    .es-pdp .cutout {\n      position: relative;\n      width: 100%;\n      height: 100%;\n      background: #fefdfe center / contain no-repeat;\n      border-radius: 10%;\n      border: 1px solid var(--line);\n      overflow: hidden;\n    }\n\n    .es-pdp .cutout--landscape {\n      background-image: url('{{ \"cat_w.svg\" | file_url }}');\n    }\n\n    .es-pdp .cutout--portrait {\n      background-image: url('{{ \"cat_h.svg\" | file_url }}');\n    }\n\n    .es-pdp .size-name {\n      margin: 0;\n      color: var(--text-primary);\n      font-weight: 700;\n      font-size: clamp(16px, 1.7vw, 22px);\n      letter-spacing: -0.02em;\n    }\n\n    .es-pdp .size-name small {\n      display: block;\n      margin-top: 4px;\n      font-weight: 500;\n      font-size: 11px;\n      letter-spacing: 0;\n      color: var(--text-muted);\n    }\n\n    /* 6. 주문 안내 (callout) */\n    .es-pdp .notice-rule {\n      height: 1px;\n      background: var(--line-strong);\n      opacity: 0.5;\n      width: 100%;\n      margin: 0 0 36px;\n    }\n\n    .es-pdp .notice-list {\n      list-style: none;\n      margin: 0;\n      padding: 0;\n      display: grid;\n      gap: clamp(14px, 1.5vw, 20px);\n    }\n\n    .es-pdp .notice-list li {\n      display: grid;\n      grid-template-columns: 18px 1fr;\n      column-gap: 16px;\n      align-items: start;\n      color: var(--text-primary);\n      font-size: clamp(14px, 1.4vw, 17px);\n      line-height: 1.7;\n    }\n\n    .es-pdp .notice-list li::before {\n      content: \"★\";\n      color: var(--accent-coral);\n      font-size: 11px;\n      line-height: 1.9;\n    }\n\n    .es-pdp .notice-list em {\n      font-style: normal;\n      font-weight: 700;\n      text-decoration: underline;\n      text-decoration-color: var(--accent-coral);\n      text-decoration-thickness: 1px;\n      text-underline-offset: 4px;\n    }\n\n    /* 7. 색상 (RGB / CMYK) */\n    .es-pdp .color-diagrams {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: clamp(32px, 5vw, 64px);\n      max-width: 720px;\n      margin: 0 auto;\n      justify-items: center;\n    }\n\n    .es-pdp .color-model {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 24px;\n    }\n\n    .es-pdp .color-pill {\n      background: var(--text-primary);\n      color: var(--text-inverse);\n      padding: 8px 22px;\n      border-radius: 999px;\n      font-size: 13px;\n      font-weight: 700;\n      letter-spacing: 0.18em;\n    }\n\n    .es-pdp .color-venn {\n      width: clamp(180px, 22vw, 240px);\n      height: auto;\n      display: block;\n      overflow: visible;\n      isolation: isolate;\n    }\n\n    .es-pdp .color-venn--rgb circle {\n      mix-blend-mode: screen;\n    }\n\n    .es-pdp .color-venn--cmyk circle {\n      mix-blend-mode: multiply;\n    }\n\n    .es-pdp .heading-block .sub strong {\n      color: var(--text-primary);\n      font-weight: 700;\n    }\n\n    @media (max-width: 860px) {\n      .es-pdp .es-page {\n        width: min(100% - 28px, var(--max));\n        padding: 36px 0 60px;\n      }\n\n      .es-pdp .es-section { margin-bottom: 72px; }\n\n      .es-pdp .es-section-shell { padding: 24px 4px; }\n\n      .es-pdp .es-notice-section .es-section-shell { padding: 40px 22px; }\n\n      .es-pdp .photo-pair,\n      .es-pdp .option-compare,\n      .es-pdp .size-grid,\n      .es-pdp .examples,\n      .es-pdp .color-diagrams {\n        grid-template-columns: 1fr;\n      }\n\n      .es-pdp .photo-frame { min-height: 320px; }\n      .es-pdp .single-photo { max-width: 100%; }\n\n      .es-pdp .option-image {\n        max-width: 340px;\n        width: 100%;\n        margin: 0 auto;\n      }\n\n      .es-pdp .mockup-wrap {\n        max-width: 320px;\n        margin: 0 auto;\n      }\n\n      .es-pdp .examples {\n        justify-items: center;\n        gap: 38px;\n      }\n\n      .es-pdp .measure-box.orientation-h,\n      .es-pdp .measure-box.orientation-v { --size: 200px; }\n    }\n  </style>\n\n  {%- comment -%}\n    비-Package 판별자 — Shopify 셋업에 맞춰 이 1곳만 수정.\n    후보: product.type / product.tags contains 'package' / product.metafields.custom.is_package\n    (실제 컨벤션 미확정 — 셋업 확인 후 확정할 것)\n  {%- endcomment -%}\n  {%- assign is_package = false -%}\n  {%- if product.type == 'Package' -%}{%- assign is_package = true -%}{%- endif -%}\n\n  <div class=\"es-pdp\" lang=\"en\">\n    <div class=\"es-page\">\n\n      <!-- Options — Material 은 전 상품 공용, Size 는 비-Package 만.\n           NOTE(follow-up): is_package 일 때 option-compare 가 Material 1개만 →\n           1fr 1fr grid 좌측 정렬. Package 단일 옵션 센터링은 후속 디자인 작업. -->\n      <section class=\"es-section\" aria-label=\"Options\">\n        <div class=\"es-section-shell\">\n          <div class=\"heading-block\">\n            <span class=\"es-eyebrow\">Options</span>\n            <h2>Choose your options.</h2>\n          </div>\n\n          <div class=\"option-compare\">\n            {%- unless is_package -%}\n            <article class=\"option-block\">\n              <h3 class=\"option-title\">Size</h3>\n              <div class=\"option-image\">\n                <div class=\"image-placeholder\">Size comparison<br>0.75\" · 1\" · 1.25\" · 1.5\" · 2\" · 2.5\"</div>\n              </div>\n              <p class=\"option-detail\">\n                <strong>0.75\" · 1\" · 1.25\" · 1.5\" · 2\" · 2.5\"</strong>\n                Size is set by the longest edge.\n                Six sizes, from 0.75\" (19 mm) to 2.5\" (64 mm).\n              </p>\n            </article>\n            {%- endunless -%}\n\n            <article class=\"option-block\">\n              <h3 class=\"option-title\">Material</h3>\n              <div class=\"option-image\">\n                <div class=\"image-placeholder\">Material samples<br>White Matte · Pearl Grey · Silver · Gold</div>\n              </div>\n              <p class=\"option-detail\">\n                <strong>White Matte · Pearl Grey · Silver · Gold</strong>\n                Inkjet stock laminated with LAMat-AF / Oraguard.\n                All four finishes are waterproof.\n              </p>\n            </article>\n          </div>\n        </div>\n      </section>\n\n      {%- unless is_package -%}\n      <!-- Sizes — 비-Package 전용. Package 는 size 선택 없음(tier 큐레이션),\n           해당 카피는 product-specific intro metafield 가 담당. -->\n      <section class=\"es-section\" aria-label=\"Sizes\">\n        <div class=\"es-section-shell\">\n          <div class=\"heading-block\">\n            <span class=\"es-eyebrow\">Sizes</span>\n            <h2>One sheet, one size.</h2>\n            <p class=\"sub\">\n              Every order is one A5 sheet (148 × 210 mm) in the size you choose.\n              The sheet stays the same — only the number of stickers changes with size.\n            </p>\n          </div>\n\n          <section class=\"size-grid\">\n            <article class=\"size-card\">\n              <h3 class=\"size-title\">0.75\" <small>19 mm</small></h3>\n              <div class=\"mockup-wrap\">\n                <div class=\"measure-top\"><span class=\"measure-label-top\">148 mm</span></div>\n                <div class=\"measure-left\"><span class=\"measure-label-left\">210 mm</span></div>\n                <img class=\"sheet-image\"\n                     src=\"{{ 'solo_0.75in.png' | file_url }}\"\n                     alt=\"0.75-inch size sheet preview — 19 mm stickers\">\n              </div>\n              <p class=\"caption\">About [count] per sheet. For a corner of a page, small labels, fingernail-size details.</p>\n            </article>\n\n            <article class=\"size-card\">\n              <h3 class=\"size-title\">1\" <small>25 mm · default</small></h3>\n              <div class=\"mockup-wrap\">\n                <div class=\"measure-top\"><span class=\"measure-label-top\">148 mm</span></div>\n                <div class=\"measure-left\"><span class=\"measure-label-left\">210 mm</span></div>\n                <img class=\"sheet-image\"\n                     src=\"{{ 'solo_01in.png' | file_url }}\"\n                     alt=\"1-inch size sheet preview — 25 mm stickers, 36 per sheet\">\n              </div>\n              <p class=\"caption\">About 36 per sheet. Good for planners, phone cases, water bottles.</p>\n            </article>\n\n            <article class=\"size-card\">\n              <h3 class=\"size-title\">1.25\" <small>32 mm</small></h3>\n              <div class=\"mockup-wrap\">\n                <div class=\"measure-top\"><span class=\"measure-label-top\">148 mm</span></div>\n                <div class=\"measure-left\"><span class=\"measure-label-left\">210 mm</span></div>\n                <img class=\"sheet-image\"\n                     src=\"{{ 'solo_01.25in.png' | file_url }}\"\n                     alt=\"1.25-inch size sheet preview — 32 mm stickers, 20 per sheet\">\n              </div>\n              <p class=\"caption\">About 20 per sheet. Good for tumblers and laptop covers.</p>\n            </article>\n\n            <article class=\"size-card\">\n              <h3 class=\"size-title\">1.5\" <small>38 mm</small></h3>\n              <div class=\"mockup-wrap\">\n                <div class=\"measure-top\"><span class=\"measure-label-top\">148 mm</span></div>\n                <div class=\"measure-left\"><span class=\"measure-label-left\">210 mm</span></div>\n                <img class=\"sheet-image\"\n                     src=\"{{ 'solo_01.5in.png' | file_url }}\"\n                     alt=\"1.5-inch size sheet preview — 38 mm stickers, 16 per sheet\">\n              </div>\n              <p class=\"caption\">About 16 per sheet. For laptops, large tumblers, a single bold placement.</p>\n            </article>\n\n            <article class=\"size-card\">\n              <h3 class=\"size-title\">2\" <small>51 mm</small></h3>\n              <div class=\"mockup-wrap\">\n                <div class=\"measure-top\"><span class=\"measure-label-top\">148 mm</span></div>\n                <div class=\"measure-left\"><span class=\"measure-label-left\">210 mm</span></div>\n                <img class=\"sheet-image\"\n                     src=\"{{ 'solo_02in.png' | file_url }}\"\n                     alt=\"2-inch size sheet preview — 51 mm stickers\">\n              </div>\n              <p class=\"caption\">About [count] per sheet. Good for laptops, backpacks, iPad cases.</p>\n            </article>\n\n            <article class=\"size-card\">\n              <h3 class=\"size-title\">2.5\" <small>64 mm</small></h3>\n              <div class=\"mockup-wrap\">\n                <div class=\"measure-top\"><span class=\"measure-label-top\">148 mm</span></div>\n                <div class=\"measure-left\"><span class=\"measure-label-left\">210 mm</span></div>\n                <img class=\"sheet-image\"\n                     src=\"{{ 'solo_02.5in.png' | file_url }}\"\n                     alt=\"2.5-inch size sheet preview — 64 mm stickers\">\n              </div>\n              <p class=\"caption\">About [count] per sheet. For a car, a large backpack, one face of a desktop.</p>\n            </article>\n          </section>\n\n          <div class=\"size-rule\">\n            <strong>By the longest edge</strong>\n            Landscape and portrait photos share the same long-edge length; only the short edge changes with the photo's ratio.\n          </div>\n\n          <section class=\"measure-group\">\n            <div class=\"examples\">\n              <article class=\"example\">\n                <div class=\"measure-box orientation-h\">\n                  <div class=\"guide-square\"></div>\n                  <div class=\"horizontal-measure\"></div>\n                  <div class=\"measure-text measure-text--top\">Long edge — sets the size</div>\n                  <div class=\"cutout cutout--landscape\"></div>\n                </div>\n                <p class=\"size-name\">Landscape photo<small>width sets the size</small></p>\n              </article>\n              <article class=\"example\">\n                <div class=\"measure-box orientation-v\">\n                  <div class=\"guide-square\"></div>\n                  <div class=\"vertical-measure\"></div>\n                  <div class=\"measure-text measure-text--side\">Long edge — sets the size</div>\n                  <div class=\"cutout cutout--portrait\"></div>\n                </div>\n                <p class=\"size-name\">Portrait photo<small>height sets the size</small></p>\n              </article>\n            </div>\n          </section>\n        </div>\n      </section>\n      {%- endunless -%}\n\n      <!-- Before you order (pearl-grey callout) — 전 상품 공용 -->\n      <section class=\"es-section es-notice-section\" aria-label=\"Order and production notes\">\n        <div class=\"es-section-shell\">\n          <div class=\"heading-block\">\n            <span class=\"es-eyebrow\">Before you order</span>\n            <h2>A few notes.</h2>\n          </div>\n          <div class=\"notice-rule\"></div>\n\n          <ul class=\"notice-list\">\n            <li>\n              <span>\n                Every sheet is made to order.\n                Once production begins, <em>we can't refund a change of mind.</em>\n              </span>\n            </li>\n            <li>\n              <span>\n                The photo and order notes you submit at checkout are what we work from.\n                We proceed from your notes, with no separate proof step.\n              </span>\n            </li>\n            <li>\n              <span>\n                Please send a sharp, high-resolution photo.\n                <em>If a photo is too blurry or low quality, we may ask for a replacement before we start.</em>\n              </span>\n            </li>\n            <li>\n              <span>\n                Printing and cutting take <em>1–3 business days</em>, and we ship the same or next day.\n              </span>\n            </li>\n            <li>\n              <span>\n                From order to shipment usually takes <em>2–5 business days</em>.\n              </span>\n            </li>\n            <li>\n              <span>\n                Printing and cutting can vary by about 0.2–2 mm.\n              </span>\n            </li>\n            <li>\n              <span>\n                <em>Screen color and printed color can differ.</em>\n                See the color note below.\n              </span>\n            </li>\n            <li>\n              <span>The number of stickers can change with the photo's ratio.</span>\n            </li>\n            <li>\n              <span>\n                <em>Free shipping across Ontario</em> (Canada Post lettermail).\n                <em>Toronto studio pickup</em> is also available.\n              </span>\n            </li>\n            <li>\n              <span>\n                Questions? Email <em>orders@everstory-domain.com</em>. We're happy to help in English or Korean.\n              </span>\n            </li>\n          </ul>\n        </div>\n      </section>\n\n      <!-- Photo quality — 전 상품 공용 -->\n      <section class=\"es-section\" aria-label=\"Photo quality\">\n        <div class=\"es-section-shell\">\n          <div class=\"heading-block\">\n            <span class=\"es-eyebrow\">Photo quality</span>\n            <h2>Send a sharp photo.</h2>\n          </div>\n\n          <div class=\"option-compare\">\n            <article class=\"option-block\">\n              <h3 class=\"option-title\">\n                <svg class=\"status-icon status-icon--ok\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n                  <circle cx=\"12\" cy=\"12\" r=\"9\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"4\"/>\n                </svg>\n                Works\n              </h3>\n              <div class=\"option-image\">\n                <img src=\"{{ 'teo_focused.png' | file_url }}\" alt=\"Example of a sharply focused photo\">\n              </div>\n              <p class=\"option-detail\">A sharply focused photo</p>\n            </article>\n\n            <article class=\"option-block\">\n              <h3 class=\"option-title\">\n                <svg class=\"status-icon status-icon--no\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n                  <line x1=\"7\" y1=\"7\" x2=\"17\" y2=\"17\" stroke=\"currentColor\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n                  <line x1=\"7\" y1=\"17\" x2=\"17\" y2=\"7\" stroke=\"currentColor\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n                </svg>\n                Hard to use\n              </h3>\n              <div class=\"option-image\">\n                <img src=\"{{ 'teo_outfocused.png' | file_url }}\" alt=\"Example of a blurry photo — replacement requested before we start\">\n              </div>\n              <p class=\"option-detail\">Blurry or shaky photo · replacement requested before we start</p>\n            </article>\n          </div>\n        </div>\n      </section>\n\n      <!-- Color — 전 상품 공용 -->\n      <section class=\"es-section\" aria-label=\"Color note\">\n        <div class=\"es-section-shell\">\n          <div class=\"heading-block\">\n            <span class=\"es-eyebrow\">Color</span>\n            <h2>Screen color and print color.</h2>\n            <p class=\"sub\">\n              <strong>Monitors</strong> render color in <strong>RGB</strong> and <strong>print</strong> in <strong>CMYK</strong>,\n              so tone, brightness, and saturation can shift slightly.\n            </p>\n          </div>\n\n          <div class=\"color-diagrams\">\n            <article class=\"color-model\">\n              <span class=\"color-pill\">RGB</span>\n              <svg class=\"color-venn color-venn--rgb\" viewBox=\"0 0 200 200\" role=\"img\" aria-label=\"RGB additive color model\">\n                <circle cx=\"100\" cy=\"74\" r=\"50\" fill=\"#1A2BFF\" />\n                <circle cx=\"72\" cy=\"125\" r=\"50\" fill=\"#1FCC1F\" />\n                <circle cx=\"128\" cy=\"125\" r=\"50\" fill=\"#FF1A1A\" />\n              </svg>\n            </article>\n\n            <article class=\"color-model\">\n              <span class=\"color-pill\">CMYK</span>\n              <svg class=\"color-venn color-venn--cmyk\" viewBox=\"0 0 200 200\" role=\"img\" aria-label=\"CMYK subtractive color model\">\n                <circle cx=\"100\" cy=\"74\" r=\"50\" fill=\"#DF1F8A\" />\n                <circle cx=\"72\" cy=\"125\" r=\"50\" fill=\"#FFE500\" />\n                <circle cx=\"128\" cy=\"125\" r=\"50\" fill=\"#00B5DC\" />\n              </svg>\n            </article>\n          </div>\n        </div>\n      </section>\n    </div>\n  </div>",
        "color_scheme": "",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
