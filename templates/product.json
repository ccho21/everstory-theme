    "custom_liquid_YXWHeB": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<html lang=\"ko\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Everstory Studio — 상품 상세 설명</title>\n  <style>\n    :root {\n      /* Brand tokens — docs/design/tokens.json (colors.web) */\n      --text-primary:   #000000;\n      --text-secondary: #4A4A4A;\n      --text-muted:     #8A8580;\n      --text-inverse:   #FFFFFF;\n      --accent-coral:   #FBAAA8;\n\n      --bg-canvas:  #FEFDFE;\n      --bg-muted:   #F8F5F2;\n      --bg-warm:    #E0D3CB;\n\n      --line:        #ECE6E0;\n      --line-strong: #1A1A1A;\n\n      /* Editorial / luxury: no drop shadows, no panel borders, sharp corners.\n         Depth comes from spacing + bg.warm callouts. */\n      --max: 1120px;\n    }\n\n    * { box-sizing: border-box; }\n\n    html, body {\n      margin: 0;\n      min-height: 100%;\n    }\n\n    body {\n      background: var(--bg-canvas);\n      color: var(--text-primary);\n      font-family: 'Pretendard', 'Apple SD Gothic Neo', 'Noto Sans KR',\n                   -apple-system, BlinkMacSystemFont, system-ui, sans-serif;\n      font-weight: 500;\n      letter-spacing: -0.02em;\n      -webkit-font-smoothing: antialiased;\n      word-break: keep-all;\n    }\n\n    /* English brand wordmark — sheet mockup tiny-mark, RGB/CMYK headings */\n    .wordmark {\n      font-family: 'Cormorant Garamond', 'Playfair Display', Georgia, serif;\n      font-weight: 600;\n      font-style: italic;\n      letter-spacing: 0;\n    }\n\n    .page {\n      width: min(var(--max), calc(100% - 36px));\n      margin: 0 auto;\n      padding: 56px 0 88px;\n    }\n\n    .section {\n      margin: 0 0 112px;\n    }\n\n    .section:last-child {\n      margin-bottom: 0;\n    }\n\n    .section-shell {\n      padding: clamp(28px, 4vw, 56px) clamp(20px, 4vw, 56px);\n    }\n\n    /* notice 섹션만 pearl-grey callout block 유지 */\n    .notice-section .section-shell {\n      background: var(--bg-warm);\n      padding: clamp(48px, 6vw, 88px) clamp(28px, 5vw, 72px);\n    }\n\n    /* Eyebrow — 작은 uppercase coral 라벨 */\n    .eyebrow {\n      display: block;\n      margin: 0 0 18px;\n      color: var(--accent-coral);\n      font-size: clamp(10px, 1vw, 12px);\n      font-weight: 700;\n      letter-spacing: 0.22em;\n      text-transform: uppercase;\n      text-align: center;\n    }\n\n    /* 통일된 섹션 헤딩: eyebrow + h2 + (optional) sub */\n    .heading-block {\n      text-align: center;\n      margin: 0 0 56px;\n    }\n\n    .heading-block h2 {\n      margin: 0;\n      font-weight: 700;\n      font-size: clamp(26px, 3.4vw, 42px);\n      line-height: 1.25;\n      letter-spacing: -0.035em;\n      color: var(--text-primary);\n    }\n\n    .heading-block .sub {\n      margin: 18px auto 0;\n      max-width: 620px;\n      color: var(--text-secondary);\n      font-size: clamp(14px, 1.4vw, 17px);\n      line-height: 1.85;\n    }\n\n    .copy {\n      max-width: 720px;\n      margin: 0 auto;\n      text-align: center;\n      color: var(--text-secondary);\n      font-size: clamp(15px, 1.5vw, 18px);\n      line-height: 1.85;\n    }\n\n    .image-placeholder {\n      width: 100%;\n      height: 100%;\n      min-height: 220px;\n      display: grid;\n      place-items: center;\n      text-align: center;\n      color: var(--text-muted);\n      font-size: 12px;\n      letter-spacing: 0.04em;\n      line-height: 1.6;\n      padding: 24px;\n      background: var(--bg-muted);\n    }\n\n    img {\n      display: block;\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n    }\n\n    code {\n      background: var(--bg-muted);\n      padding: 2px 6px;\n      font-size: 12px;\n      letter-spacing: 0;\n    }\n\n    /* 1. 제품 소개 */\n    .photo-pair {\n      display: grid;\n      grid-template-columns: 1fr 0.9fr;\n      gap: 18px;\n      margin-bottom: 44px;\n    }\n\n    .photo-frame {\n      min-height: 460px;\n      background: var(--bg-muted);\n      overflow: hidden;\n    }\n\n    .single-photo {\n      max-width: 760px;\n      margin: 0 auto 36px;\n      background: var(--bg-muted);\n      overflow: hidden;\n      aspect-ratio: 4 / 3;\n    }\n\n    /* 2. SKU 카드 */\n    .sku-grid {\n      display: grid;\n      grid-template-columns: repeat(4, 1fr);\n      gap: 22px;\n    }\n\n    .sku-card { text-align: center; }\n\n    .sku-card .sku-image {\n      aspect-ratio: 1 / 1.2;\n      background: var(--bg-muted);\n      overflow: hidden;\n      margin-bottom: 16px;\n    }\n\n    .sku-card h3 {\n      margin: 0 0 6px;\n      font-weight: 700;\n      font-size: clamp(18px, 1.9vw, 24px);\n      letter-spacing: -0.02em;\n      color: var(--text-primary);\n    }\n\n    .sku-card .sku-meta {\n      margin: 0 0 8px;\n      color: var(--text-muted);\n      font-size: 13px;\n      letter-spacing: -0.01em;\n    }\n\n    .sku-card .sku-price {\n      margin: 0;\n      color: var(--text-primary);\n      font-weight: 700;\n      font-size: clamp(14px, 1.4vw, 17px);\n    }\n\n    /* 3. 옵션 */\n    .option-compare {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 36px;\n    }\n\n    .option-block { display: grid; gap: 16px; }\n\n    .option-title {\n      margin: 0;\n      text-align: center;\n      color: var(--text-primary);\n      font-size: 15px;\n      font-weight: 700;\n      letter-spacing: -0.01em;\n    }\n\n    .option-image {\n      aspect-ratio: 4 / 5;\n      background: var(--bg-muted);\n      overflow: hidden;\n    }\n\n    .option-detail {\n      text-align: center;\n      color: var(--text-secondary);\n      font-size: 14px;\n      line-height: 1.75;\n    }\n\n    .option-detail strong {\n      display: block;\n      margin-bottom: 4px;\n      color: var(--text-primary);\n      font-weight: 700;\n    }\n\n    /* 4. 시트 구성 */\n    .size-grid {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 56px 42px;\n    }\n\n    .size-card { min-width: 0; text-align: center; }\n\n    .size-title {\n      margin: 0 0 16px;\n      font-weight: 700;\n      font-size: clamp(17px, 1.9vw, 22px);\n      letter-spacing: -0.02em;\n      color: var(--text-primary);\n    }\n\n    .size-title small {\n      margin-left: 8px;\n      font-weight: 500;\n      font-size: 12px;\n      letter-spacing: 0;\n      color: var(--text-muted);\n      vertical-align: middle;\n    }\n\n    .mockup-wrap {\n      position: relative;\n      padding: 26px 26px 22px;\n      background: var(--bg-canvas);\n    }\n\n    .measure-top {\n      position: absolute;\n      top: 10px;\n      left: 26px;\n      right: 26px;\n      height: 1px;\n      background: var(--accent-coral);\n    }\n\n    .measure-top::before,\n    .measure-top::after {\n      content: \"\";\n      position: absolute;\n      top: -4px;\n      width: 1px;\n      height: 8px;\n      background: var(--accent-coral);\n    }\n\n    .measure-top::before { left: 0; }\n    .measure-top::after { right: 0; }\n\n    .measure-label-top {\n      position: absolute;\n      top: -14px;\n      left: 50%;\n      transform: translateX(-50%);\n      color: var(--accent-coral);\n      font-size: 10px;\n      letter-spacing: 0.04em;\n    }\n\n    .measure-left {\n      position: absolute;\n      top: 26px;\n      bottom: 22px;\n      left: 10px;\n      width: 1px;\n      background: var(--accent-coral);\n    }\n\n    .measure-left::before,\n    .measure-left::after {\n      content: \"\";\n      position: absolute;\n      left: -4px;\n      width: 8px;\n      height: 1px;\n      background: var(--accent-coral);\n    }\n\n    .measure-left::before { top: 0; }\n    .measure-left::after { bottom: 0; }\n\n    .measure-label-left {\n      position: absolute;\n      left: -22px;\n      top: 50%;\n      transform: translateY(-50%) rotate(-90deg);\n      color: var(--accent-coral);\n      font-size: 10px;\n      letter-spacing: 0.04em;\n      white-space: nowrap;\n    }\n\n    /* A5 시트 mockup */\n    .sheet {\n      aspect-ratio: 148 / 195;\n      background: var(--bg-canvas);\n      padding: 16px;\n      display: flex;\n      flex-direction: column;\n      overflow: hidden;\n      outline: 1px solid var(--line);\n      outline-offset: -1px;\n    }\n\n    .sheet-header {\n      height: 22px;\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 6px;\n      border-bottom: 1px solid var(--line);\n      padding-bottom: 4px;\n      color: var(--text-primary);\n      font-size: 7px;\n      letter-spacing: 0.14em;\n      text-transform: uppercase;\n    }\n\n    .sheet-header .tiny-mark {\n      font-size: 10px;\n      letter-spacing: 0;\n      text-transform: none;\n    }\n\n    .sample-area {\n      flex: 1;\n      display: grid;\n      place-items: center;\n      padding: 14px 0;\n    }\n\n    .face-grid {\n      width: 100%;\n      display: grid;\n      justify-items: center;\n      align-items: center;\n      gap: 10px;\n    }\n\n    .face-grid.s   { grid-template-columns: repeat(3, 1fr); gap: 14px; }\n    .face-grid.m   { grid-template-columns: repeat(3, 1fr); gap: 16px 14px; }\n    .face-grid.l   { grid-template-columns: repeat(2, 1fr); gap: 18px; }\n    .face-grid.mix { grid-template-columns: repeat(4, 1fr); gap: 10px; }\n\n    .face {\n      width: var(--face-size);\n      aspect-ratio: 1 / 1;\n      border-radius: 50%;\n      background:\n        radial-gradient(circle at 52% 56%, #ffe1d3 0 35%, transparent 36%),\n        radial-gradient(circle at 37% 45%, #2d2520 0 3%, transparent 4%),\n        radial-gradient(circle at 63% 45%, #2d2520 0 3%, transparent 4%),\n        radial-gradient(ellipse at 50% 78%, #d76d72 0 4%, transparent 5%),\n        radial-gradient(ellipse at 50% 28%, #3b2923 0 28%, transparent 29%);\n      background-color: #f8cdbd;\n      border: 1px solid #fff;\n    }\n\n    .face.xs     { --face-size: 22px; }\n    .face.small  { --face-size: 32px; }\n    .face.medium { --face-size: 44px; }\n    .face.large  { --face-size: 60px; }\n    .face.xlarge { --face-size: 76px; }\n\n    .sheet-footer {\n      height: 14px;\n      border-top: 1px solid var(--line);\n      padding-top: 3px;\n      display: flex;\n      align-items: end;\n      justify-content: space-between;\n      color: var(--text-muted);\n      font-size: 6px;\n      letter-spacing: 0.16em;\n      text-transform: uppercase;\n    }\n\n    .sheet-footer .heart {\n      color: var(--accent-coral);\n      font-size: 8px;\n    }\n\n    .caption {\n      margin: 16px 0 0;\n      color: var(--text-secondary);\n      font-size: 13px;\n      line-height: 1.7;\n    }\n\n    /* 5. 사이즈 가이드 */\n    .measure-group {\n      margin-top: 56px;\n    }\n\n    .measure-group:first-of-type { margin-top: 0; }\n\n    .group-label {\n      width: fit-content;\n      margin: 0 auto 40px;\n      padding-bottom: 8px;\n      border-bottom: 1px solid var(--text-primary);\n      color: var(--text-primary);\n      text-align: center;\n      font-size: 13px;\n      letter-spacing: 0.02em;\n      font-weight: 700;\n    }\n\n    .examples {\n      display: grid;\n      grid-template-columns: 1fr 1fr 1fr;\n      align-items: end;\n      gap: clamp(34px, 5vw, 64px);\n    }\n\n    .example {\n      text-align: center;\n      display: grid;\n      justify-items: center;\n      gap: 14px;\n    }\n\n    .measure-box {\n      --size: 180px;\n      width: var(--size);\n      height: var(--size);\n      position: relative;\n      display: grid;\n      place-items: center;\n    }\n\n    .measure-box.size-l { --size: 240px; }\n    .measure-box.size-m { --size: 180px; }\n    .measure-box.size-s { --size: 130px; }\n\n    .guide-square {\n      position: absolute;\n      inset: 0;\n      border: 1px dotted rgba(0, 0, 0, 0.28);\n    }\n\n    .vertical-measure {\n      position: absolute;\n      left: -36px;\n      top: 8px;\n      bottom: 8px;\n      width: 1px;\n      background: var(--accent-coral);\n    }\n\n    .vertical-measure::before,\n    .vertical-measure::after {\n      content: \"\";\n      position: absolute;\n      left: -4px;\n      width: 8px;\n      height: 1px;\n      background: var(--accent-coral);\n    }\n\n    .vertical-measure::before { top: 0; }\n    .vertical-measure::after { bottom: 0; }\n\n    .measure-text {\n      position: absolute;\n      left: -70px;\n      top: 50%;\n      transform: translateY(-50%) rotate(-90deg);\n      color: var(--accent-coral);\n      font-size: clamp(13px, 1.3vw, 16px);\n      letter-spacing: 0.04em;\n      line-height: 1;\n      white-space: nowrap;\n      font-weight: 700;\n    }\n\n    .cutout {\n      position: relative;\n      width: 78%;\n      height: 78%;\n      border-radius: 50%;\n      background:\n        radial-gradient(circle at 38% 44%, #2a211d 0 3%, transparent 4%),\n        radial-gradient(circle at 62% 44%, #2a211d 0 3%, transparent 4%),\n        radial-gradient(ellipse at 50% 73%, #e28183 0 5%, transparent 6%),\n        radial-gradient(ellipse at 50% 30%, #3b2923 0 32%, transparent 33%),\n        radial-gradient(circle at 50% 54%, #ffe1d3 0 52%, transparent 53%);\n      background-color: #f7d0c0;\n      border: 2px solid #fff;\n      overflow: hidden;\n    }\n\n    .size-name {\n      margin: 0;\n      color: var(--text-primary);\n      font-weight: 700;\n      font-size: clamp(16px, 1.7vw, 22px);\n      letter-spacing: -0.02em;\n    }\n\n    .size-name small {\n      display: block;\n      margin-top: 4px;\n      font-weight: 500;\n      font-size: 11px;\n      letter-spacing: 0;\n      color: var(--text-muted);\n    }\n\n    /* 6. 주문 안내 (callout) */\n    .notice-rule {\n      height: 1px;\n      background: var(--line-strong);\n      opacity: 0.5;\n      width: 100%;\n      margin: 0 0 36px;\n    }\n\n    .notice-list {\n      list-style: none;\n      margin: 0;\n      padding: 0;\n      display: grid;\n      gap: clamp(14px, 1.5vw, 20px);\n    }\n\n    .notice-list li {\n      display: grid;\n      grid-template-columns: 18px 1fr;\n      column-gap: 16px;\n      align-items: start;\n      color: var(--text-primary);\n      font-size: clamp(14px, 1.4vw, 17px);\n      line-height: 1.7;\n    }\n\n    .notice-list li::before {\n      content: \"★\";\n      color: var(--accent-coral);\n      font-size: 11px;\n      line-height: 1.9;\n    }\n\n    .notice-list em {\n      font-style: normal;\n      font-weight: 700;\n      text-decoration: underline;\n      text-decoration-color: var(--accent-coral);\n      text-decoration-thickness: 1px;\n      text-underline-offset: 4px;\n    }\n\n    /* 7. 보정 안내 */\n    .retouch-block {\n      margin-top: 48px;\n    }\n\n    .retouch-block:first-of-type { margin-top: 0; }\n\n    .retouch-block h3 {\n      margin: 0 0 6px;\n      text-align: center;\n      font-weight: 700;\n      font-size: 15px;\n      letter-spacing: -0.01em;\n      color: var(--text-primary);\n    }\n\n    .retouch-block .sub {\n      margin: 0 0 22px;\n      text-align: center;\n      font-size: 13px;\n      color: var(--text-muted);\n    }\n\n    .possible-flow {\n      display: grid;\n      grid-template-columns: 1fr 40px 1fr;\n      align-items: center;\n      gap: 12px;\n      max-width: 560px;\n      margin: 0 auto;\n    }\n\n    .retouch-image {\n      aspect-ratio: 1 / 1;\n      background: var(--bg-muted);\n      overflow: hidden;\n    }\n\n    .arrow {\n      text-align: center;\n      font-size: 22px;\n      color: var(--text-muted);\n      user-select: none;\n    }\n\n    .impossible-grid {\n      display: grid;\n      grid-template-columns: repeat(3, minmax(0, 1fr));\n      gap: 14px;\n      max-width: 560px;\n      margin: 0 auto;\n    }\n\n    /* 8. 색상 (RGB / CMYK) */\n    .diagram-row {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 32px;\n      max-width: 720px;\n      margin: 0 auto;\n    }\n\n    .diagram-card {\n      background: var(--bg-muted);\n      padding: 36px 32px;\n      text-align: center;\n    }\n\n    .diagram-card h3 {\n      margin: 0 0 18px;\n      font-family: 'Cormorant Garamond', 'Playfair Display', Georgia, serif;\n      font-weight: 600;\n      font-style: italic;\n      font-size: 38px;\n      letter-spacing: 0.02em;\n      color: var(--text-primary);\n    }\n\n    .diagram-card svg {\n      display: block;\n      width: 100%;\n      height: auto;\n      overflow: visible;\n    }\n\n    .diagram-card .caption {\n      font-size: 11px;\n      letter-spacing: 0.18em;\n      text-transform: uppercase;\n      color: var(--text-muted);\n      margin-top: 18px;\n      text-align: center;\n    }\n\n    /* Utility */\n    .replace-note {\n      margin-top: 56px;\n      padding: 18px 22px;\n      border: 1px dashed var(--line);\n      background: var(--bg-muted);\n      color: var(--text-secondary);\n      font-size: 12px;\n      line-height: 1.75;\n    }\n\n    .replace-note strong {\n      display: block;\n      margin-bottom: 6px;\n      font-weight: 700;\n      color: var(--text-primary);\n    }\n\n    @media (max-width: 860px) {\n      .page {\n        width: min(100% - 28px, var(--max));\n        padding: 36px 0 60px;\n      }\n\n      .section { margin-bottom: 72px; }\n\n      .section-shell { padding: 24px 4px; }\n\n      .notice-section .section-shell { padding: 40px 22px; }\n\n      .photo-pair,\n      .sku-grid,\n      .option-compare,\n      .size-grid,\n      .examples,\n      .diagram-row {\n        grid-template-columns: 1fr;\n      }\n\n      .photo-frame { min-height: 320px; }\n      .single-photo { max-width: 100%; }\n\n      .option-image {\n        max-width: 340px;\n        width: 100%;\n        margin: 0 auto;\n      }\n\n      .mockup-wrap {\n        max-width: 320px;\n        margin: 0 auto;\n      }\n\n      .examples {\n        justify-items: center;\n        gap: 38px;\n      }\n\n      .measure-box.size-l { --size: 220px; }\n      .measure-box.size-m { --size: 170px; }\n      .measure-box.size-s { --size: 130px; }\n\n      .possible-flow {\n        grid-template-columns: 1fr;\n        max-width: 240px;\n      }\n\n      .arrow { transform: rotate(90deg); }\n\n      .impossible-grid {\n        grid-template-columns: 1fr;\n        max-width: 220px;\n        margin-inline: auto;\n      }\n    }\n  </style>\n</head>\n<body>\n  <main class=\"page\">\n\n    <!-- 1. 제품 소개 / 사용 예시 -->\n    <section class=\"section\" aria-label=\"제품 소개 및 사용 예시\">\n      <div class=\"section-shell\">\n        <div class=\"heading-block\">\n          <span class=\"eyebrow\">Made to keep</span>\n          <h2>버리지 않고 두고두고 쓰는 시트.</h2>\n        </div>\n\n        <div class=\"photo-pair\">\n          <div class=\"photo-frame\">\n            <div class=\"image-placeholder\">사용 예시 1<br>A5 스티커 시트 사진</div>\n          </div>\n          <div class=\"photo-frame\">\n            <div class=\"image-placeholder\">사용 예시 2<br>다이어리 · 폰케이스 · 텀블러 부착</div>\n          </div>\n        </div>\n\n        <p class=\"copy\">\n          사진을 손으로 정리해 잘라낸 우리 아이 · 반려동물 커스텀 스티커입니다.\n          흰 배경과 얇은 아웃라인으로 다이어리, 폰케이스, 텀블러, 노트북처럼\n          매끈한 면에 가장 잘 어울려요.\n        </p>\n      </div>\n    </section>\n\n    <!-- 2. 포장 안내 -->\n    <section class=\"section\" aria-label=\"포장 안내\">\n      <div class=\"section-shell\">\n        <div class=\"heading-block\">\n          <span class=\"eyebrow\">Packaging</span>\n          <h2>한 장씩 손으로 포장합니다.</h2>\n        </div>\n\n        <div class=\"single-photo\">\n          <div class=\"image-placeholder\">포장 예시<br>주문 수량별 스튜디오 포장</div>\n        </div>\n\n        <p class=\"copy\">\n          주문하신 수량만큼 한 장 한 장 정성스럽게 포장해 보내드려요. 1장 주문도 환영합니다.\n        </p>\n      </div>\n    </section>\n\n    <!-- 3. 시트 종류 선택 -->\n    <section class=\"section\" aria-label=\"시트 종류 선택\">\n      <div class=\"section-shell\">\n        <div class=\"heading-block\">\n          <span class=\"eyebrow\">Choose your sheet</span>\n          <h2>사진 한 장, 또는 여러 장.</h2>\n        </div>\n\n        <div class=\"sku-grid\">\n          <article class=\"sku-card\">\n            <div class=\"sku-image\">\n              <div class=\"image-placeholder\">Solo<br>시트 미리보기</div>\n            </div>\n            <h3>Solo</h3>\n            <p class=\"sku-meta\">사진 1장 · A5 시트 1장</p>\n            <p class=\"sku-price\">$15.99 CAD</p>\n          </article>\n\n          <article class=\"sku-card\">\n            <div class=\"sku-image\">\n              <div class=\"image-placeholder\">Duo<br>시트 미리보기</div>\n            </div>\n            <h3>Duo</h3>\n            <p class=\"sku-meta\">사진 2장 · A5 시트 1장</p>\n            <p class=\"sku-price\">$18.99 CAD</p>\n          </article>\n\n          <article class=\"sku-card\">\n            <div class=\"sku-image\">\n              <div class=\"image-placeholder\">Trio<br>시트 미리보기</div>\n            </div>\n            <h3>Trio</h3>\n            <p class=\"sku-meta\">사진 3장 · A5 시트 1장</p>\n            <p class=\"sku-price\">$21.99 CAD</p>\n          </article>\n\n          <article class=\"sku-card\">\n            <div class=\"sku-image\">\n              <div class=\"image-placeholder\">Memory Pack<br>시트 2장 미리보기</div>\n            </div>\n            <h3>Memory Pack</h3>\n            <p class=\"sku-meta\">사진 4장 이상 · A5 시트 2장</p>\n            <p class=\"sku-price\">$28.99 CAD</p>\n          </article>\n        </div>\n      </div>\n    </section>\n\n    <!-- 4. 옵션 -->\n    <section class=\"section\" aria-label=\"옵션 안내\">\n      <div class=\"section-shell\">\n        <div class=\"heading-block\">\n          <span class=\"eyebrow\">Options</span>\n          <h2>옵션 선택.</h2>\n        </div>\n\n        <div class=\"option-compare\">\n          <article class=\"option-block\">\n            <h3 class=\"option-title\">사이즈</h3>\n            <div class=\"option-image\">\n              <div class=\"image-placeholder\">사이즈 비교<br>XS · S · M · L · XL · XXL · Mixed</div>\n            </div>\n            <p class=\"option-detail\">\n              <strong>XS · S · M · L · XL · XXL · Mixed</strong>\n              가장 긴 변을 기준으로 사이즈를 정해요.\n              0.75\"(19 mm) 부터 2.5\"(64 mm) 까지 6종 + Mixed.\n            </p>\n          </article>\n\n          <article class=\"option-block\">\n            <h3 class=\"option-title\">재질</h3>\n            <div class=\"option-image\">\n              <div class=\"image-placeholder\">재질 샘플<br>White Matte · Pearl Grey · Silver · Gold</div>\n            </div>\n            <p class=\"option-detail\">\n              <strong>White Matte · Pearl Grey · Silver · Gold</strong>\n              한국 프리미엄 substrate, LAMat-AF / Oraguard 라미네이팅.\n              4종 모두 방수입니다.\n            </p>\n          </article>\n        </div>\n      </div>\n    </section>\n\n    <!-- 5. 시트 구성 -->\n    <section class=\"section\" aria-label=\"A5 시트 구성\">\n      <div class=\"section-shell\">\n        <div class=\"heading-block\">\n          <span class=\"eyebrow\">On one A5 sheet</span>\n          <h2>A5 한 시트, 손으로 배치.</h2>\n          <p class=\"sub\">\n            A5 시트 (148 × 195 mm) 안에 선택하신 사이즈에 맞춰 한 장씩 손으로 배치합니다.\n            시트는 한 사이즈, 스티커 개수만 사이즈에 따라 달라집니다.\n          </p>\n        </div>\n\n        <section class=\"size-grid\">\n          <article class=\"size-card\">\n            <h3 class=\"size-title\">스몰 S <small>1\" · 25 mm · 기본</small></h3>\n            <div class=\"mockup-wrap\">\n              <div class=\"measure-top\"><span class=\"measure-label-top\">148 mm</span></div>\n              <div class=\"measure-left\"><span class=\"measure-label-left\">195 mm</span></div>\n              <div class=\"sheet\">\n                <div class=\"sheet-header\">\n                  <span>DEAR · ORDER NO.</span>\n                  <span class=\"tiny-mark wordmark\">Everstory</span>\n                </div>\n                <div class=\"sample-area\">\n                  <div class=\"face-grid s\">\n                    <span class=\"face small\"></span><span class=\"face small\"></span><span class=\"face small\"></span>\n                    <span class=\"face small\"></span><span class=\"face small\"></span><span class=\"face small\"></span>\n                    <span class=\"face small\"></span>\n                  </div>\n                </div>\n                <div class=\"sheet-footer\">\n                  <span class=\"wordmark\" style=\"text-transform:none;letter-spacing:0;font-size:7px;\">Everstory Studio</span>\n                  <span class=\"heart\">♡</span>\n                </div>\n              </div>\n            </div>\n            <p class=\"caption\">한 시트 약 7장. 다이어리, 폰케이스, 물병에 적합.</p>\n          </article>\n\n          <article class=\"size-card\">\n            <h3 class=\"size-title\">미디움 M <small>1.25\" · 32 mm</small></h3>\n            <div class=\"mockup-wrap\">\n              <div class=\"measure-top\"><span class=\"measure-label-top\">148 mm</span></div>\n              <div class=\"measure-left\"><span class=\"measure-label-left\">195 mm</span></div>\n              <div class=\"sheet\">\n                <div class=\"sheet-header\">\n                  <span>DEAR · ORDER NO.</span>\n                  <span class=\"tiny-mark wordmark\">Everstory</span>\n                </div>\n                <div class=\"sample-area\">\n                  <div class=\"face-grid m\">\n                    <span class=\"face medium\"></span><span class=\"face medium\"></span>\n                    <span class=\"face medium\"></span><span class=\"face medium\"></span>\n                    <span class=\"face medium\"></span>\n                  </div>\n                </div>\n                <div class=\"sheet-footer\">\n                  <span class=\"wordmark\" style=\"text-transform:none;letter-spacing:0;font-size:7px;\">Everstory Studio</span>\n                  <span class=\"heart\">♡</span>\n                </div>\n              </div>\n            </div>\n            <p class=\"caption\">한 시트 약 5장. 텀블러, 노트북 커버에 적합.</p>\n          </article>\n\n          <article class=\"size-card\">\n            <h3 class=\"size-title\">라지 L <small>1.5\" · 38 mm</small></h3>\n            <div class=\"mockup-wrap\">\n              <div class=\"measure-top\"><span class=\"measure-label-top\">148 mm</span></div>\n              <div class=\"measure-left\"><span class=\"measure-label-left\">195 mm</span></div>\n              <div class=\"sheet\">\n                <div class=\"sheet-header\">\n                  <span>DEAR · ORDER NO.</span>\n                  <span class=\"tiny-mark wordmark\">Everstory</span>\n                </div>\n                <div class=\"sample-area\">\n                  <div class=\"face-grid l\">\n                    <span class=\"face large\"></span><span class=\"face large\"></span>\n                    <span class=\"face large\"></span>\n                  </div>\n                </div>\n                <div class=\"sheet-footer\">\n                  <span class=\"wordmark\" style=\"text-transform:none;letter-spacing:0;font-size:7px;\">Everstory Studio</span>\n                  <span class=\"heart\">♡</span>\n                </div>\n              </div>\n            </div>\n            <p class=\"caption\">한 시트 약 3장. 노트북, 대형 텀블러, 임팩트 있는 단독 배치.</p>\n          </article>\n\n          <article class=\"size-card\">\n            <h3 class=\"size-title\">믹스 Mixed <small>1\" · 1.25\" · 1.75\" 조합</small></h3>\n            <div class=\"mockup-wrap\">\n              <div class=\"measure-top\"><span class=\"measure-label-top\">148 mm</span></div>\n              <div class=\"measure-left\"><span class=\"measure-label-left\">195 mm</span></div>\n              <div class=\"sheet\">\n                <div class=\"sheet-header\">\n                  <span>DEAR · ORDER NO.</span>\n                  <span class=\"tiny-mark wordmark\">Everstory</span>\n                </div>\n                <div class=\"sample-area\">\n                  <div class=\"face-grid mix\">\n                    <span class=\"face xlarge\" style=\"grid-column: span 2; grid-row: span 2;\"></span>\n                    <span class=\"face medium\"></span><span class=\"face medium\"></span>\n                    <span class=\"face medium\"></span><span class=\"face medium\"></span>\n                    <span class=\"face small\"></span><span class=\"face small\"></span><span class=\"face small\"></span><span class=\"face small\"></span>\n                  </div>\n                </div>\n                <div class=\"sheet-footer\">\n                  <span class=\"wordmark\" style=\"text-transform:none;letter-spacing:0;font-size:7px;\">Everstory Studio</span>\n                  <span class=\"heart\">♡</span>\n                </div>\n              </div>\n            </div>\n            <p class=\"caption\">한 시트 안에 여러 사이즈를 큐레이션. 용도별로 골라 쓸 수 있어요.</p>\n          </article>\n        </section>\n      </div>\n    </section>\n\n    <!-- 6. 사이즈 가이드 -->\n    <section class=\"section\" aria-label=\"사이즈 안내\">\n      <div class=\"section-shell\">\n        <div class=\"heading-block\">\n          <span class=\"eyebrow\">Sizes</span>\n          <h2>가장 긴 변 기준.</h2>\n          <p class=\"sub\">\n            각 스티커는 가장 긴 변을 기준으로 사이즈를 정합니다.\n            세로 사진과 가로 사진이 같은 사이즈 라벨일 때 긴 변 길이는 같고,\n            짧은 변만 사진 비율에 따라 달라져요.\n          </p>\n        </div>\n\n        <section class=\"measure-group\">\n          <div class=\"group-label\">작은 사이즈 — XS · S · M</div>\n          <div class=\"examples\">\n            <article class=\"example\">\n              <div class=\"measure-box size-s\">\n                <div class=\"guide-square\"></div>\n                <div class=\"vertical-measure\"></div>\n                <div class=\"measure-text\">19 mm</div>\n                <div class=\"cutout\"></div>\n              </div>\n              <p class=\"size-name\">XS<small>0.75\" · 19 mm</small></p>\n            </article>\n            <article class=\"example\">\n              <div class=\"measure-box size-m\">\n                <div class=\"guide-square\"></div>\n                <div class=\"vertical-measure\"></div>\n                <div class=\"measure-text\">25 mm</div>\n                <div class=\"cutout\"></div>\n              </div>\n              <p class=\"size-name\">S<small>1\" · 25 mm · 기본</small></p>\n            </article>\n            <article class=\"example\">\n              <div class=\"measure-box size-l\">\n                <div class=\"guide-square\"></div>\n                <div class=\"vertical-measure\"></div>\n                <div class=\"measure-text\">32 mm</div>\n                <div class=\"cutout\"></div>\n              </div>\n              <p class=\"size-name\">M<small>1.25\" · 32 mm</small></p>\n            </article>\n          </div>\n        </section>\n\n        <section class=\"measure-group\">\n          <div class=\"group-label\">큰 사이즈 — L · XL · XXL</div>\n          <div class=\"examples\">\n            <article class=\"example\">\n              <div class=\"measure-box size-s\">\n                <div class=\"guide-square\"></div>\n                <div class=\"vertical-measure\"></div>\n                <div class=\"measure-text\">38 mm</div>\n                <div class=\"cutout\"></div>\n              </div>\n              <p class=\"size-name\">L<small>1.5\" · 38 mm</small></p>\n            </article>\n            <article class=\"example\">\n              <div class=\"measure-box size-m\">\n                <div class=\"guide-square\"></div>\n                <div class=\"vertical-measure\"></div>\n                <div class=\"measure-text\">45 mm</div>\n                <div class=\"cutout\"></div>\n              </div>\n              <p class=\"size-name\">XL<small>1.75\" · 45 mm</small></p>\n            </article>\n            <article class=\"example\">\n              <div class=\"measure-box size-l\">\n                <div class=\"guide-square\"></div>\n                <div class=\"vertical-measure\"></div>\n                <div class=\"measure-text\">64 mm</div>\n                <div class=\"cutout\"></div>\n              </div>\n              <p class=\"size-name\">XXL<small>2.5\" · 64 mm</small></p>\n            </article>\n          </div>\n        </section>\n      </div>\n    </section>\n\n    <!-- 7. 주문 전 안내 (pearl-grey callout) -->\n    <section class=\"section notice-section\" aria-label=\"주문 및 제작 안내\">\n      <div class=\"section-shell\">\n        <div class=\"heading-block\">\n          <span class=\"eyebrow\">Before you order</span>\n          <h2>주문 전 안내.</h2>\n        </div>\n        <div class=\"notice-rule\"></div>\n\n        <ul class=\"notice-list\">\n          <li>\n            <span>\n              모든 시트는 주문 후 제작되는 맞춤 상품이에요.\n              제작 시작 후 단순 변심에 의한 <em>환불은 어렵습니다.</em>\n            </span>\n          </li>\n          <li>\n            <span>\n              결제 시 업로드한 사진과 주문 노트가 작업의 기준이 됩니다.\n              별도의 시안 단계 없이 노트 기준으로 작업을 진행해요.\n            </span>\n          </li>\n          <li>\n            <span>선명하고 해상도가 높은 사진일수록 결과물이 좋아져요.</span>\n          </li>\n          <li>\n            <span>\n              인쇄·컷팅은 <em>1–3 영업일</em> 소요되며, 출고는 당일 또는 익일에 진행됩니다.\n            </span>\n          </li>\n          <li>\n            <span>\n              주문일 기준 출고까지 보통 <em>2–5 영업일</em> 정도 소요될 수 있습니다.\n            </span>\n          </li>\n          <li>\n            <span>\n              인쇄·컷팅 특성상 0.2–2 mm 정도의 오차나 밀림이 발생할 수 있습니다.\n            </span>\n          </li>\n          <li>\n            <span>\n              <em>화면 색상과 실제 인쇄물의 색상에는 차이가 있을 수 있습니다.</em>\n              아래 색상 안내 참고.\n            </span>\n          </li>\n          <li>\n            <span>사진 비율에 따라 스티커 개수가 달라질 수 있습니다.</span>\n          </li>\n          <li>\n            <span>\n              <em>온타리오 전역 무료 배송</em> (Canada Post lettermail).\n              <em>토론토 스튜디오 픽업</em>도 가능합니다.\n            </span>\n          </li>\n          <li>\n            <span>\n              문의는 <em>orders@everstory-domain.com</em> 으로 보내주세요. 한국어 응대 가능합니다.\n            </span>\n          </li>\n        </ul>\n      </div>\n    </section>\n\n    <!-- 8. 보정 안내 -->\n    <section class=\"section\" aria-label=\"보정 안내\">\n      <div class=\"section-shell\">\n        <div class=\"heading-block\">\n          <span class=\"eyebrow\">Retouching</span>\n          <h2>보정 안내.</h2>\n          <p class=\"sub\">\n            눈곱, 작은 피부 잡티, 가벼운 상처 같은 간단한 보정은 주문 노트에 함께 적어주세요.\n            객체의 큰 면적을 가리거나 형태 자체를 바꾸는 경우는 보정이 어렵습니다.\n          </p>\n        </div>\n\n        <section class=\"retouch-block\">\n          <h3>가능한 보정 예시</h3>\n          <p class=\"sub\">피부의 점, 작은 상처 등 깔끔하게 제거 가능</p>\n\n          <div class=\"possible-flow\">\n            <div class=\"retouch-image\"><div class=\"image-placeholder\">Before</div></div>\n            <div class=\"arrow\">→</div>\n            <div class=\"retouch-image\"><div class=\"image-placeholder\">After</div></div>\n          </div>\n        </section>\n\n        <section class=\"retouch-block\">\n          <h3>불가능한 보정 예시</h3>\n          <p class=\"sub\">큰 면적을 가리거나 객체의 형태를 바꾸는 경우는 어렵습니다</p>\n\n          <div class=\"impossible-grid\">\n            <div class=\"retouch-image\"><div class=\"image-placeholder\">불가 예시 1</div></div>\n            <div class=\"retouch-image\"><div class=\"image-placeholder\">불가 예시 2</div></div>\n            <div class=\"retouch-image\"><div class=\"image-placeholder\">불가 예시 3</div></div>\n          </div>\n        </section>\n      </div>\n    </section>\n\n    <!-- 9. 색상 안내 -->\n    <section class=\"section\" aria-label=\"색상 유의사항\">\n      <div class=\"section-shell\">\n        <div class=\"heading-block\">\n          <span class=\"eyebrow\">Color</span>\n          <h2>화면 색상과 인쇄 색상.</h2>\n          <p class=\"sub\">\n            모니터·스마트폰은 RGB, 인쇄물은 CMYK 영역에서 표현되며,\n            톤·밝기·채도에 약간의 차이가 생길 수 있습니다.\n          </p>\n        </div>\n\n        <div class=\"diagram-row\">\n          <article class=\"diagram-card\">\n            <h3>RGB</h3>\n            <svg viewBox=\"0 0 360 260\" role=\"img\" aria-label=\"RGB 색상 모델\">\n              <circle cx=\"180\" cy=\"88\" r=\"86\" fill=\"#254db5\" fill-opacity=\"0.88\"/>\n              <circle cx=\"120\" cy=\"174\" r=\"86\" fill=\"#67b52d\" fill-opacity=\"0.88\"/>\n              <circle cx=\"240\" cy=\"174\" r=\"86\" fill=\"#e81721\" fill-opacity=\"0.88\"/>\n              <circle cx=\"180\" cy=\"148\" r=\"39\" fill=\"#fffdf8\" fill-opacity=\"0.8\"/>\n            </svg>\n            <p class=\"caption\">화면 · RGB</p>\n          </article>\n\n          <article class=\"diagram-card\">\n            <h3>CMYK</h3>\n            <svg viewBox=\"0 0 360 260\" role=\"img\" aria-label=\"CMYK 색상 모델\">\n              <circle cx=\"180\" cy=\"88\" r=\"86\" fill=\"#cf0f73\" fill-opacity=\"0.88\"/>\n              <circle cx=\"120\" cy=\"174\" r=\"86\" fill=\"#f1df18\" fill-opacity=\"0.88\"/>\n              <circle cx=\"240\" cy=\"174\" r=\"86\" fill=\"#168fc4\" fill-opacity=\"0.88\"/>\n              <circle cx=\"180\" cy=\"148\" r=\"39\" fill=\"#171615\" fill-opacity=\"0.92\"/>\n            </svg>\n            <p class=\"caption\">인쇄 · CMYK</p>\n          </article>\n        </div>\n      </div>\n    </section>\n  </main>\n</body>",
        "color_scheme": "",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
